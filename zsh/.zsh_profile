ZSH_CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/zsh-conf"

# conf.d in numeric order (utils, env, path, tools, keybindings, aliases, manpager)
for f in "$ZSH_CONF_DIR"/conf.d/*.zsh(N); do source "$f"; done

# Function overrides (after conf.d so OMZ aliases can be overridden)
for f in "$ZSH_CONF_DIR"/functions/*.zsh(N); do source "$f"; done
